# Copy to .env and fill in. Used by docker-compose.yml.
# See docs/docker.md for the full reference.

# First-run only (seeds the initial admin account; ignored once a user exists).
NEXUS_ADMIN_USER=admin
NEXUS_ADMIN_PASSWORD=change-me

# TMDb v3 API key — required for Add-media metadata search. Write-only.
NEXUS_TMDB_API_KEY=

# Optional: pin a stable API key (otherwise randomised each start).
NEXUS_API_KEY=

# Optional: reverse-proxy subpath, e.g. /nexus (blank = served at root).
NEXUS_URL_BASE=

# Optional: log level (debug | info | warn | error).
NEXUS_LOG_LEVEL=info
